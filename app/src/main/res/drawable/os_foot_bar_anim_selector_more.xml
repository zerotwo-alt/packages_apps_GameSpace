    <item android:id="@id/point" android:drawable="@drawable/os_vector_foot_opt_bar_points" />
    <transition android:drawable="@drawable/os_foot_bar_anim_vector_point_to_arrow" android:toId="@id/arrow" android:fromId="@id/point" />
    <transition android:drawable="@drawable/os_foot_bar_anim_vector_arrow_to_point" android:toId="@id/point" android:fromId="@id/arrow" />
</animated-selector>
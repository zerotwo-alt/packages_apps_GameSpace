<?xml version="1.0" encoding="utf-8"?>
<ripple android:color="@color/os_btn_ripple_color"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <layer-list>
            <item android:top="1.0px" android:right="1.0px" android:bottom="1.0px">
                <shape android:shape="rectangle">
                    <solid android:color="@color/os_btn_solid_light" />
                </shape>
            </item>
            <item android:gravity="top">
                <shape android:shape="rectangle">
                    <solid android:color="@color/os_btn_stroke_light" />
                    <size android:height="1.0px" />
                </shape>
            </item>
            <item android:gravity="right">
                <shape android:shape="rectangle">
                    <solid android:color="@color/os_btn_stroke_light" />
                    <size android:width="1.0px" />
                </shape>
            </item>
            <item android:gravity="bottom">
                <shape android:shape="rectangle">
                    <solid android:color="@color/os_btn_stroke_light" />
                    <size android:height="1.0px" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
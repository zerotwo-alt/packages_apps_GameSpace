<?xml version="1.0" encoding="utf-8"?>
<ripple android:color="@color/os_btn_ripple_color"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/mask">
        <inset>
            <shape android:shape="rectangle">
                <corners android:radius="@dimen/os_btn_corners_radius" />
                <solid android:color="@android:color/white" />
                <padding android:left="@dimen/os_btn_text_padding" android:right="@dimen/os_btn_text_padding" />
                <size android:height="@dimen/os_btn_min_height" android:width="@dimen/os_btn_min_width" />
            </shape>
        </inset>
    </item>
</ripple>
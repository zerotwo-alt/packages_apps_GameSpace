<?xml version="1.0" encoding="utf-8"?>
<animated-selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true" android:id="@id/checked" android:drawable="@drawable/os_check_drawable_end_checked" />
    <item android:id="@id/unchecked" android:drawable="@drawable/os_check_drawable_start_unchecked" />
    <transition android:drawable="@drawable/os_check_drawable_checked_to_unchecked" android:toId="@id/unchecked" android:fromId="@id/checked" />
    <transition android:drawable="@drawable/os_check_drawable_unchecked_to_checked" android:toId="@id/checked" android:fromId="@id/unchecked" />
</animated-selector>
<?xml version="1.0" encoding="utf-8"?>
<ripple android:color="@color/os_btn_ripple_color"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <inset>
            <shape android:shape="rectangle">
                <corners android:radius="@dimen/os_btn_corners_radius" />
                <stroke android:width="@dimen/os_btn_stroke_width" android:color="@color/os_btn_stroke_light" />
                <solid android:color="@color/os_btn_solid_light" />
                <padding android:left="@dimen/os_btn_text_padding" android:right="@dimen/os_btn_text_padding" />
            </shape>
        </inset>
    </item>
</ripple>
<?xml version="1.0" encoding="utf-8"?>
<ripple android:color="@color/os_dialog_divider_color"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <inset>
            <layer-list>
                <item android:top="1.0px">
                    <shape android:shape="rectangle">
                        <solid android:color="@color/os_dialog_background_color" />
                    </shape>
                </item>
                <item android:gravity="top" android:height="1.0px">
                    <shape android:shape="rectangle">
                        <solid android:color="@color/os_dialog_divider_color" />
                    </shape>
                </item>
            </layer-list>
        </inset>
    </item>
</ripple>